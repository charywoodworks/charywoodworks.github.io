---
interface Props {
  stepNumber: number;
  title: string;
  description: string;
  icon: string;
}

const { stepNumber, title, description, icon } = Astro.props;
---

<div class="flex flex-col items-center text-center p-4">
  <div class="relative flex items-center justify-center w-14 h-14 rounded-full bg-amber-100 text-amber-800 mb-3">
    <span class="absolute -top-2 -right-2 w-6 h-6 flex items-center justify-center bg-wood-600 text-white text-xs font-bold rounded-full">
      {stepNumber}
    </span>
    <!-- Icon placeholder using step icon name -->
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      {icon === 'message-circle' && <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" />}
      {icon === 'clipboard-list' && <><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" /><path stroke-linecap="round" stroke-linejoin="round" d="M9 5a2 2 0 012-2h2a2 2 0 012 2M9 5h6M9 12h6M9 16h3" /></>}
      {icon === 'map-pin' && <><path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></>}
      {icon === 'layout' && <><rect x="3" y="3" width="18" height="18" rx="2" /><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18M9 21V9" /></>}
      {icon === 'layers' && <><path stroke-linecap="round" stroke-linejoin="round" d="M12 2l10 6.5v7L12 22 2 15.5v-7L12 2z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 22v-7" /><path stroke-linecap="round" stroke-linejoin="round" d="M22 8.5l-10 7-10-7" /></>}
      {icon === 'file-text' && <><path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></>}
      {icon === 'handshake' && <path stroke-linecap="round" stroke-linejoin="round" d="M20 17l-2-2m0 0l-4-4m4 4l4-4m-4 4l-2 2M4 7l4 4m0 0l4 4m-4-4L4 15m4-4l2-2m6-2a2 2 0 100-4 2 2 0 000 4z" />}
      {icon === 'calendar' && <><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></>}
      {icon === 'hammer' && <path stroke-linecap="round" stroke-linejoin="round" d="M15 12l-8.5 8.5a2.12 2.12 0 01-3-3L12 9m3 3l4.5-4.5a2.12 2.12 0 00-3-3L12 9m3 3l-3-3" />}
      {icon === 'truck' && <><rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></>}
      {icon === 'thumbs-up' && <path stroke-linecap="round" stroke-linejoin="round" d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3" />}
    </svg>
  </div>
  <h3 class="font-semibold text-stone-800 text-sm sm:text-base mb-1">{title}</h3>
  <p class="text-xs sm:text-sm text-stone-600 leading-relaxed">{description}</p>
</div>
