---
interface Props {
  customerName: string;
  projectType: string;
  reviewText: string;
  rating?: number;
  source: 'manual' | 'google';
}

const { customerName, projectType, reviewText, rating, source } = Astro.props;

const initial = customerName.charAt(0).toUpperCase();
---

<article class="bg-white rounded-xl shadow-sm border border-stone-200 p-6 flex flex-col h-full">
  <!-- Header: Initial + Name -->
  <div class="flex items-center gap-3 mb-4">
    <div class="w-10 h-10 rounded-full bg-amber-700 text-white flex items-center justify-center font-semibold text-lg flex-shrink-0" aria-hidden="true">
      {initial}
    </div>
    <div>
      <h3 class="font-semibold text-stone-800 text-sm">{customerName}</h3>
      <span class="inline-block text-xs bg-stone-100 text-stone-600 px-2 py-0.5 rounded-full mt-0.5">
        {projectType}
      </span>
    </div>
  </div>

  <!-- Rating (optional) -->
  {rating && (
    <div class="flex items-center gap-0.5 mb-3" aria-label={`Rating: ${rating} out of 5 stars`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class:list={[
            'w-4 h-4',
            i < rating ? 'text-amber-400' : 'text-stone-200',
          ]}
          fill="currentColor"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  )}

  <!-- Review Text -->
  <blockquote class="text-stone-600 text-sm leading-relaxed flex-1">
    <p>"{reviewText}"</p>
  </blockquote>

  <!-- Source Indicator -->
  <div class="mt-4 pt-3 border-t border-stone-100">
    {source === 'google' ? (
      <span class="text-xs text-stone-400 flex items-center gap-1">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Google Review
      </span>
    ) : (
      <span class="text-xs text-stone-400">Verified Customer</span>
    )}
  </div>
</article>
