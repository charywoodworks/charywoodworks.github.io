---
import WhatsAppCTA from './WhatsAppCTA.astro';
import homepageData from '../data/homepage.json';

const { heroHeadline, heroSubheadline, heroCTAText, heroCTAMessage } = homepageData;
---

<section class="relative text-white overflow-hidden">
  <!-- Hero background image -->
  <div class="absolute inset-0">
    <img src="/images/placeholders/hero-bg.jpg" alt="" class="w-full h-full object-cover" width="1920" height="1080" />
    <div class="absolute inset-0 bg-black/70"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 py-16 sm:py-24 lg:py-32">
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold leading-tight mb-4 text-white drop-shadow-lg">
        {heroHeadline}
      </h1>
      <p class="text-base sm:text-lg text-white/90 mb-8 max-w-xl leading-relaxed drop-shadow-md">
        {heroSubheadline}
      </p>
      <WhatsAppCTA
        message={heroCTAMessage}
        label={heroCTAText}
        variant="primary"
        size="lg"
      />
    </div>
  </div>
</section>
