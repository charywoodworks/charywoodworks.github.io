---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---

<article class="bg-white rounded-xl border border-stone-200 p-6 shadow-sm hover:shadow-md transition-shadow">
  {icon && (
    <div class="w-12 h-12 bg-wood-50 rounded-lg flex items-center justify-center mb-4 text-2xl">
      {icon}
    </div>
  )}
  <h3 class="text-lg font-semibold text-stone-800 mb-2">{title}</h3>
  <p class="text-stone-600 text-sm leading-relaxed">{description}</p>
</article>
