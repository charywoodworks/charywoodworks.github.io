---
interface Props {
  title: string;
  image: string;
  imageAlt: string;
  isPlaceholder: boolean;
  materialType: string;
  dimensions: string;
  finishType: string;
  location: string;
  category: string;
  whatsappMessage: string;
}

const { title, image, imageAlt, isPlaceholder, materialType, dimensions, finishType, location, category, whatsappMessage } = Astro.props;

import siteData from '../data/site.json';
const whatsappUrl = `https://wa.me/${siteData.whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<article class="bg-white rounded-xl shadow-sm overflow-hidden border border-stone-200 hover:shadow-md transition-shadow">
  <div class="relative aspect-[4/3]">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
      width="800"
      height="600"
    />
    {isPlaceholder && (
      <span class="absolute top-2 left-2 bg-amber-500 text-white text-xs font-medium px-2 py-1 rounded">
        Sample
      </span>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-semibold text-stone-800 text-lg">{title}</h3>
    <div class="mt-2 grid grid-cols-2 gap-1 text-sm text-stone-600">
      <span>📐 {dimensions}</span>
      <span>🪵 {materialType}</span>
      <span>✨ {finishType}</span>
      <span>📍 {location}</span>
    </div>
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 block w-full text-center bg-green-700 text-white py-3 rounded-lg font-medium hover:bg-green-800 transition-colors min-h-[44px]"
      aria-label={`Request similar design for ${title} via WhatsApp`}
    >
      Request Similar Design
    </a>
  </div>
</article>
