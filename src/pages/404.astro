---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import siteData from '../data/site.json';
---

<BaseLayout
  title="Page Not Found | Chary Woodworks"
  description="The page you're looking for doesn't exist. Browse our woodworking services or contact us on WhatsApp."
  url="/404"
>
  <Fragment slot="schema">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <section class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <!-- 404 Illustration -->
      <div class="mb-8">
        <svg class="w-32 h-32 mx-auto text-wood-300" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Sawdust/wood shavings stylized icon -->
          <circle cx="60" cy="60" r="56" stroke="currentColor" stroke-width="3" stroke-dasharray="8 4" />
          <path d="M40 50 L60 35 L80 50 L80 80 L40 80 Z" stroke="currentColor" stroke-width="3" fill="none" />
          <rect x="53" y="60" width="14" height="20" stroke="currentColor" stroke-width="2.5" fill="none" rx="1" />
          <circle cx="60" cy="70" r="2" fill="currentColor" />
          <line x1="35" y1="85" x2="85" y2="85" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-wood-800">
        Page Not Found
      </h1>

      <!-- Friendly message -->
      <p class="mt-4 text-lg text-stone-600 leading-relaxed">
        Looks like this page has been moved or doesn't exist anymore. Don't worry — let's help you find what you're looking for.
      </p>

      <!-- Navigation Links -->
      <nav class="mt-10" aria-label="Helpful pages">
        <h2 class="text-sm font-medium text-stone-500 uppercase tracking-wider mb-4">
          Browse Our Pages
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/" class="px-4 py-2 bg-wood-50 text-wood-700 rounded-lg font-medium hover:bg-wood-100 transition-colors min-h-[44px] inline-flex items-center">
            Home
          </a>
          <a href="/products" class="px-4 py-2 bg-wood-50 text-wood-700 rounded-lg font-medium hover:bg-wood-100 transition-colors min-h-[44px] inline-flex items-center">
            Products
          </a>
          <a href="/gallery" class="px-4 py-2 bg-wood-50 text-wood-700 rounded-lg font-medium hover:bg-wood-100 transition-colors min-h-[44px] inline-flex items-center">
            Gallery
          </a>
          <a href="/hire-carpenter" class="px-4 py-2 bg-wood-50 text-wood-700 rounded-lg font-medium hover:bg-wood-100 transition-colors min-h-[44px] inline-flex items-center">
            Services
          </a>
          <a href="/about" class="px-4 py-2 bg-wood-50 text-wood-700 rounded-lg font-medium hover:bg-wood-100 transition-colors min-h-[44px] inline-flex items-center">
            About
          </a>
        </div>
      </nav>

      <!-- WhatsApp CTA -->
      <div class="mt-10 pt-8 border-t border-stone-200">
        <p class="text-stone-600 mb-4">
          Can't find what you need? Reach out and we'll help.
        </p>
        <WhatsAppCTA
          message="Hi, I tried to visit a page on your website that doesn't exist. Can you help me find what I'm looking for?"
          label="Ask Us on WhatsApp"
          variant="primary"
          size="lg"
        />
      </div>
    </div>
  </section>
</BaseLayout>
