---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import { getCollection } from 'astro:content';
import siteData from '../data/site.json';

const reviewEntries = await getCollection('reviews');

// Static fallback testimonials for empty state
const fallbackTestimonials = [
  {
    customerName: "Happy Customer",
    projectType: "Modular Kitchen",
    reviewText: "Great quality woodwork and professional service. The team delivered on time and the finish is excellent.",
    rating: 5,
    source: 'manual' as const,
  },
  {
    customerName: "Satisfied Client",
    projectType: "Bedroom Wardrobe",
    reviewText: "Very happy with the craftsmanship. The wardrobe fits perfectly and the internal layout is well thought out.",
    rating: 5,
    source: 'manual' as const,
  },
  {
    customerName: "Repeat Customer",
    projectType: "Complete Home Interiors",
    reviewText: "We have used their services twice now. Consistent quality, fair pricing, and reliable timelines every time.",
    rating: 5,
    source: 'manual' as const,
  },
];

const hasReviews = reviewEntries.length > 0;
---

<BaseLayout
  title="Customer Reviews - Chary Woodworks Hyderabad"
  description="Read customer reviews and testimonials for custom woodworking, modular kitchens, wardrobes, and interior work in Hyderabad."
  url="/reviews"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": siteData.businessName,
      "description": "Customer reviews for custom woodworking and carpentry services in Hyderabad",
      "url": "https://charywoodworks.github.io/reviews",
      "telephone": siteData.phone,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hyderabad",
        "addressRegion": "Telangana",
        "addressCountry": "IN"
      },
      "areaServed": "Hyderabad"
    })} />
  </Fragment>
  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page Header -->
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-stone-800 mb-4">
        Customer Reviews
      </h1>
      <p class="text-stone-600 mb-8 max-w-2xl">
        Hear from homeowners across Hyderabad who trusted us with their woodworking and interior projects.
      </p>

      <!-- Reviews Grid -->
      {hasReviews ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {reviewEntries.map(async (entry) => {
            const { Content } = await entry.render();
            return (
              <ReviewCard
                customerName={entry.data.customerName}
                projectType={entry.data.projectType}
                reviewText={entry.body || ''}
                rating={entry.data.rating}
                source={entry.data.source}
              />
            );
          })}
        </div>
      ) : (
        <!-- Empty State: Static Fallback Testimonials -->
        <div class="mb-12">
          <p class="text-stone-500 text-center mb-8">
            We're collecting reviews from our customers. Here are some testimonials from our recent projects:
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {fallbackTestimonials.map((testimonial) => (
              <ReviewCard
                customerName={testimonial.customerName}
                projectType={testimonial.projectType}
                reviewText={testimonial.reviewText}
                rating={testimonial.rating}
                source={testimonial.source}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Google Reviews Link -->
      <div class="text-center mb-12">
        <a
          href={siteData.googleBusinessProfileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-amber-700 hover:text-amber-800 font-medium transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          See our reviews on Google
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <!-- WhatsApp CTA for convinced visitors -->
      <div class="bg-green-50 rounded-xl p-8 text-center border border-green-100">
        <h2 class="text-xl md:text-2xl font-heading font-bold text-stone-800 mb-3">
          Ready to Start Your Project?
        </h2>
        <p class="text-stone-600 mb-6 max-w-lg mx-auto">
          Convinced by what our customers say? Let's discuss your woodworking project today.
        </p>
        <WhatsAppCTA
          message="Hi, I read your reviews and would like to discuss a project."
          label="Discuss Your Project"
          variant="primary"
          size="lg"
        />
      </div>
    </div>
  </section>
</BaseLayout>
