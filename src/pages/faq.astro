---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import faqs from '../data/faq.json';

const title = 'FAQ | Chary Woodworks Hyderabad';
const description = 'Find answers to common questions about custom furniture pricing, materials, timelines, service areas, and payment for woodwork in Hyderabad.';
const url = 'https://charywoodworks.github.io/faq';

// Prepare FAQ schema for rich results
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const whatsappMessage = 'Hi, I have a question that is not listed in your FAQ. I would like to know about [describe your question].';
---

<BaseLayout title={title} description={description} url={url}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-stone-900 mb-3">
          Frequently Asked Questions
        </h1>
        <p class="text-stone-600 text-lg">
          Find answers to common questions about our woodworking services in Hyderabad.
        </p>
      </div>

      <FAQAccordion faqs={faqs} />

      <div class="mt-10 text-center border-t border-stone-200 pt-8">
        <p class="text-stone-600 mb-4">
          Didn't find what you were looking for? Ask us directly on WhatsApp.
        </p>
        <WhatsAppCTA
          message={whatsappMessage}
          label="Ask a Question on WhatsApp"
          variant="primary"
          size="lg"
        />
      </div>
    </div>
  </section>
</BaseLayout>
