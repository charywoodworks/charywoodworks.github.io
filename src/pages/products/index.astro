---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { getCollection } from 'astro:content';
import siteData from '../../data/site.json';

const categories = await getCollection('categories');
const sortedCategories = categories.sort((a, b) => a.data.order - b.data.order);

const title = `Products | ${siteData.businessName} Hyderabad`;
const description = `Browse custom woodworking categories: beds, cupboards, TV units, doors, and more. Quality craftsmanship in Hyderabad.`;
const url = `${Astro.site || 'https://charywoodworks.github.io'}/products`;

const productsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Custom Woodworking Product Categories",
  "description": description,
  "url": "https://charywoodworks.github.io/products",
  "numberOfItems": sortedCategories.length,
  "itemListElement": sortedCategories.map((cat, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": cat.data.title,
    "url": `https://charywoodworks.github.io/products/${cat.slug}`,
  })),
};
---

<BaseLayout title={title} description={description} url={url}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(productsSchema)} />
  </Fragment>
  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-stone-800">
          Our Product Categories
        </h1>
        <p class="mt-3 text-lg text-stone-600 max-w-2xl mx-auto">
          Explore our range of custom woodworking products crafted to your specifications with quality materials in Hyderabad.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {sortedCategories.map((category) => (
          <CategoryCard
            title={category.data.title}
            slug={category.slug}
            shortDescription={category.data.shortDescription}
            image={category.data.image}
            imageAlt={category.data.imageAlt}
            isPlaceholder={category.data.isPlaceholder}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
