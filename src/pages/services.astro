---
import BaseLayout from '../layouts/BaseLayout.astro';
import MaterialCard from '../components/MaterialCard.astro';
import { getCollection } from 'astro:content';
import siteData from '../data/site.json';

// Fetch materials collection
const materials = await getCollection('materials');
const sortedMaterials = materials.sort((a, b) => a.data.order - b.data.order);

// Category groups with their slugs and display names
const categoryGroups = [
  {
    title: 'Furniture',
    description: 'Custom-built furniture designed and crafted for your home',
    categories: [
      { name: 'Beds', slug: 'beds' },
      { name: 'Cupboards', slug: 'cupboards' },
      { name: 'TV Units', slug: 'tv-units' },
      { name: 'Dining Tables', slug: 'dining-tables' },
      { name: 'Tea Tables', slug: 'tea-tables' },
      { name: 'Dressing Tables', slug: 'dressing-tables' },
      { name: 'Shoe Racks', slug: 'shoe-racks' },
      { name: 'Shelves & Storage Racks', slug: 'shelves-storage-racks' },
    ],
  },
  {
    title: 'Woodwork',
    description: 'Structural and decorative woodwork for interiors',
    categories: [
      { name: 'Doors', slug: 'doors' },
      { name: 'Plywood Works', slug: 'plywood-works' },
      { name: 'WPC Panel Works', slug: 'wpc-panel-works' },
      { name: 'MDF Works', slug: 'mdf-works' },
    ],
  },
  {
    title: 'Small Works',
    description: 'Specialized and custom smaller projects',
    categories: [
      { name: 'Pooja Units', slug: 'pooja-units' },
      { name: 'Other Custom Works', slug: 'other-custom-works' },
    ],
  },
];

const pageTitle = `Our Services - ${siteData.businessName}`;
const pageDescription = 'Explore our complete range of woodworking and carpentry services in Hyderabad. Custom furniture, doors, plywood works, WPC panels, and more.';
const pageUrl = '/services';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": siteData.businessName,
  "description": pageDescription,
  "url": "https://charywoodworks.github.io/services",
  "telephone": siteData.phone,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Hyderabad",
    "addressRegion": "Telangana",
    "addressCountry": "IN",
  },
  "areaServed": "Hyderabad",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Woodworking Services",
    "itemListElement": categoryGroups.flatMap(group =>
      group.categories.map(cat => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": `Custom ${cat.name} in Hyderabad`,
        },
      }))
    ),
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} url={pageUrl}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-stone-100 to-white py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-stone-900 mb-4">
        Our Services
      </h1>
      <p class="text-stone-600 text-lg max-w-2xl mx-auto">
        From custom furniture to complete interior woodwork, we deliver quality craftsmanship for every room in your home.
      </p>
    </div>
  </section>

  <!-- Grouped Categories Section -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      {categoryGroups.map((group) => (
        <div class="mb-12 last:mb-0">
          <div class="mb-6">
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900 mb-2">
              {group.title}
            </h2>
            <p class="text-stone-600">{group.description}</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {group.categories.map((category) => (
              <a
                href={`/products/${category.slug}`}
                class="group block bg-white rounded-lg border border-stone-200 p-5 hover:border-amber-400 hover:shadow-md transition-all"
              >
                <h3 class="font-semibold text-stone-800 group-hover:text-amber-700 transition-colors">
                  {category.name}
                </h3>
                <span class="text-sm text-stone-500 group-hover:text-amber-600 mt-1 inline-flex items-center gap-1">
                  View details
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Materials Section -->
  <section class="py-12 md:py-16 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900 mb-3">
          Materials We Use
        </h2>
        <p class="text-stone-600 max-w-2xl mx-auto">
          We work with a range of quality materials suited to different budgets and requirements. Each material is selected for durability and finish quality.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedMaterials.map(async (material) => {
          const { Content } = await material.render();
          // Extract the body text from the raw markdown content
          const bodyText = material.body || '';
          return (
            <MaterialCard
              name={material.data.name}
              description={bodyText}
              budgetTier={material.data.budgetTier}
              applicableCategories={material.data.applicableCategories}
              isPlaceholder={material.data.isPlaceholder}
            />
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
