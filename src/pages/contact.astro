---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import siteData from '../data/site.json';
---

<BaseLayout
  title="Contact Chary Woodworks | Hyderabad Carpentry"
  description="Contact Chary Woodworks for custom woodworking and carpentry in Hyderabad. WhatsApp, call, or email us. See our location and operating hours."
  url="/contact"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": siteData.businessName,
      "description": "Custom woodworking, carpentry, and interior solutions in Hyderabad",
      "url": "/contact",
      "telephone": siteData.phone,
      "email": siteData.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Kukatpally",
        "addressLocality": "Hyderabad",
        "addressRegion": "Telangana",
        "postalCode": "500072",
        "addressCountry": "IN"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Hyderabad, Telangana, India"
      },
      "openingHoursSpecification": siteData.operatingHours.filter(h => h.hours !== "Closed").map(h => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": h.day,
        "opens": "09:00",
        "closes": h.day === "Saturday" ? "18:00" : "19:00"
      })),
      "sameAs": [siteData.googleBusinessProfileUrl]
    })} />
  </Fragment>

  <!-- Page Header -->
  <section class="bg-wood-50 py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-wood-800">
        Contact Us
      </h1>
      <p class="mt-4 text-lg text-stone-600">
        Get in touch for custom woodworking, carpentry, and interior solutions in Hyderabad
      </p>
    </div>
  </section>

  <!-- WhatsApp CTA - Most Prominent -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="bg-green-50 border border-green-200 rounded-xl p-8 text-center">
        <h2 class="text-2xl font-heading font-bold text-wood-800 mb-3">
          Fastest Way to Reach Us
        </h2>
        <p class="text-stone-600 mb-6">
          Send us a message on WhatsApp and we'll respond promptly during business hours.
        </p>
        <WhatsAppCTA
          message="Hi, I am visiting your website and would like to enquire about your woodworking services."
          label="Chat on WhatsApp"
          variant="primary"
          size="lg"
          fullWidth={true}
        />
      </div>
    </div>
  </section>

  <!-- Contact Details -->
  <section class="bg-stone-50 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-wood-800 mb-6 text-center">
        Other Ways to Reach Us
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Phone -->
        <a
          href={`tel:${siteData.phone}`}
          class="flex items-center gap-4 bg-white p-5 rounded-lg shadow-sm border border-stone-200 hover:border-amber-300 transition-colors min-h-[44px]"
        >
          <span class="flex-shrink-0 w-11 h-11 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </span>
          <div>
            <p class="text-sm text-stone-500">Phone (tap to call)</p>
            <p class="font-medium text-wood-800">{siteData.phone}</p>
          </div>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${siteData.email}`}
          class="flex items-center gap-4 bg-white p-5 rounded-lg shadow-sm border border-stone-200 hover:border-amber-300 transition-colors min-h-[44px]"
        >
          <span class="flex-shrink-0 w-11 h-11 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </span>
          <div>
            <p class="text-sm text-stone-500">Email (tap to email)</p>
            <p class="font-medium text-wood-800">{siteData.email}</p>
          </div>
        </a>
      </div>

      <!-- Service Area -->
      <div class="mt-6 bg-white p-5 rounded-lg shadow-sm border border-stone-200">
        <div class="flex items-start gap-4">
          <span class="flex-shrink-0 w-11 h-11 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </span>
          <div>
            <p class="text-sm text-stone-500">Service Area</p>
            <p class="font-medium text-wood-800">{siteData.serviceArea}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operating Hours -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-wood-800 mb-6 text-center">
        Operating Hours
      </h2>
      <div class="bg-white rounded-lg shadow-sm border border-stone-200 overflow-hidden">
        <ul class="divide-y divide-stone-100">
          {siteData.operatingHours.map((schedule) => (
            <li class="flex items-center justify-between px-5 py-3">
              <span class="font-medium text-wood-800">{schedule.day}</span>
              <span class:list={[
                'text-sm',
                schedule.hours === 'Closed' ? 'text-red-700 font-medium' : 'text-stone-600'
              ]}>
                {schedule.hours}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="bg-stone-50 py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-heading font-bold text-wood-800 mb-6 text-center">
        Our Location
      </h2>
      <div class="rounded-lg overflow-hidden shadow-sm border border-stone-200">
        <iframe
          src={siteData.googleMapsEmbedUrl}
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Google Maps showing ${siteData.businessName} location in Hyderabad`}
          class="w-full"
        ></iframe>
      </div>
      <p class="mt-3 text-center text-sm text-stone-500">
        Having trouble viewing the map?
        <a
          href={siteData.googleMapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="text-amber-700 hover:text-amber-800 underline min-h-[44px] inline-flex items-center"
        >
          Open in Google Maps
        </a>
      </p>
    </div>
  </section>

  <!-- Google Business Profile -->
  <section class="py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl font-heading font-bold text-wood-800 mb-3">
        Find Us on Google
      </h2>
      <p class="text-stone-600 mb-6">
        View our Google Business Profile for reviews, photos, and more information.
      </p>
      <a
        href={siteData.googleBusinessProfileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-white border-2 border-stone-300 text-wood-800 font-medium px-6 py-3 rounded-lg hover:border-amber-500 hover:bg-amber-50 transition-colors min-h-[44px]"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        View Google Business Profile
      </a>
    </div>
  </section>
</BaseLayout>
